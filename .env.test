# Firebase emulator config for testing
# These values don't need to be real — emulators accept any project config
VITE_FIREBASE_API_KEY=fake-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=prepaid-ai-emulator
VITE_FIREBASE_STORAGE_BUCKET=prepaid-ai-emulator.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000
VITE_FIREBASE_APP_ID=1:000000000:web:fake
VITE_USE_EMULATORS=true
