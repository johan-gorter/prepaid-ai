rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow writes but protect the balance field (server-managed only).
      // On create: client may not set balance.
      // On update: client may not change balance from its current value.
      allow create: if request.auth != null && request.auth.uid == userId
        && !('balance' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId
        && (!('balance' in request.resource.data) || request.resource.data.balance == resource.data.balance);
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Balance transactions — read-only from client (written by Cloud Functions)
      match /balanceTransactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Notifications — read-only from client (written by Cloud Functions).
      // Responding to a notification (dismiss/accept/decline) goes through the
      // notificationResponse callable, so clients can never forge or accept a
      // gift to mint credits.
      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /renovations/{renovationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /impressions/{impressionId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // Credit transfers — escrow records for gifted credits. Fully
    // server-managed: clients never read or write them directly (the recipient
    // learns of a gift via their notifications subcollection, and both parties
    // see the effect in their own balanceTransactions). Keeping these closed
    // also means a sender can't enumerate by reading transfer docs.
    match /creditTransfers/{transferId} {
      allow read, write: if false;
    }

    // Feedback — authenticated users can create; only the author can read/delete
    match /feedback/{feedbackId} {
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Shares — single-document reads-by-token are public; list is blocked so
    // tokens can't be enumerated. Only the owner can create or delete.
    match /shares/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['ownerUid', 'resultImageUrl', 'createdAt', 'locale']);
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow update: if false;
    }

    // Measurement counters (issue #93) — anonymous aggregate `{event, source,
    // day}` docs written ONLY by the trackEvent Cloud Function via the Admin
    // SDK (which bypasses these rules). No client may read or write them: they
    // hold no per-user data and exist purely for funnel/viral-loop trends.
    match /metrics/{id} {
      allow read, write: if false;
    }
  }
}
