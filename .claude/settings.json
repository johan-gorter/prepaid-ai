{
  "permissions": {
    "allow": [
      "Bash(npm run interactive-browser:*)",
      "Bash(npm -s run interactive-browser:*)",
      "Bash(npm run interactive-screenshot:*)",
      "Bash(npm -s run interactive-screenshot:*)",
      "Bash(npm run interactive-javascript:*)",
      "Bash(npm -s run interactive-javascript:*)",
      "PowerShell(npm run interactive-browser:*)",
      "PowerShell(npm -s run interactive-browser:*)",
      "PowerShell(npm run interactive-screenshot:*)",
      "PowerShell(npm -s run interactive-screenshot:*)",
      "PowerShell(npm run interactive-javascript:*)",
      "PowerShell(npm -s run interactive-javascript:*)",
      "Bash(npx playwright install:*)",
      "PowerShell(npx playwright install:*)",
      "Bash(rm -rf temp)",
      "Bash(mkdir temp)",
      "PowerShell(Remove-Item -Recurse -Force temp:*)",
      "PowerShell(New-Item -ItemType Directory temp:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(npm -s run test:e2e:*)",
      "Bash(npm run test:e2e:*)",
      "Bash(npm -s run typecheck:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm -s run services:status:*)",
      "Bash(npm run services:status:*)",
      "Bash(npm -s run services:wait:*)",
      "Bash(npm run services:wait:*)",
      "Bash(npx vue-tsc:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts\\interactive-screenshot.mjs:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts/interactive-screenshot.mjs:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts\\interactive-javascript.mjs:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts/interactive-javascript.mjs:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts\\interactive-browser.mjs:*)",
      "Bash(cmd.exe /c \"cd /d D:\\github\\prepaid-ai && node scripts/interactive-browser.mjs:*)",
      "Bash(cmd.exe /c \"node scripts\\interactive-screenshot.mjs:*)",
      "Bash(cmd.exe /c \"node scripts/interactive-screenshot.mjs:*)",
      "Bash(cmd.exe /c \"node scripts\\interactive-javascript.mjs:*)",
      "Bash(cmd.exe /c \"node scripts/interactive-javascript.mjs:*)",
      "Bash(cmd.exe /c \"node scripts\\interactive-browser.mjs:*)",
      "Bash(cmd.exe /c \"node scripts/interactive-browser.mjs:*)",
      "Write(temp/**)",
      "Edit(temp/**)",
      "Write(/home/jgo/prepaid-ai/temp/**)",
      "Edit(/home/jgo/prepaid-ai/temp/**)",
      "Write(/mnt/d/github/prepaid-ai/temp/**)",
      "Edit(/mnt/d/github/prepaid-ai/temp/**)",
      "Bash(cat > temp/:*)",
      "Bash(cat > /home/jgo/prepaid-ai/temp/:*)",
      "Bash(cat > /mnt/d/github/prepaid-ai/temp/:*)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": ["github.com", "*.githubusercontent.com"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); for p in .env .env.local firestore.rules storage.rules; do if [[ \"$FILE\" == *\"$p\" ]]; then echo \"Blocked: $FILE is protected\" >&2; exit 2; fi; done",
            "timeout": 5,
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path // empty'); if [[ \"$FILE\" == *.ts || \"$FILE\" == *.vue ]]; then cd \"$CLAUDE_PROJECT_DIR\" && npx vue-tsc -b --noEmit 2>&1 | head -20; fi",
            "timeout": 30,
            "statusMessage": "Type checking..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminders: Vue 3 Composition API + <script setup lang=ts> only. No enums (erasableSyntaxOnly). No ESLint — rely on vue-tsc strict. All tests are Playwright (E2E/CT/PWA). E2E needs Firebase emulators running. ALL TESTS MUST PASS BEFORE PUSHING — update tests when changing app code.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
