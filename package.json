{
  "name": "prepaid-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build:functions": "npm --prefix functions run build",
    "build:emulator": "vite build --mode emulator",
    "dev": "vite",
    "dev:emulators": "vite --mode emulator",
    "prepreview:emulators": "npm run build:emulator",
    "preview:emulators": "vite preview --port 4175 --outDir dist-emulator --host localhost",
    "services:start": "node devtools/services/cli.mjs start",
    "services:stop": "node devtools/services/cli.mjs stop",
    "services:restart": "node devtools/services/cli.mjs restart",
    "services:status": "node devtools/services/cli.mjs status",
    "typecheck:tests": "vue-tsc --project tsconfig.test.json --noEmit",
    "typecheck:all": "vue-tsc -b && npm run typecheck:tests && npm run --prefix functions build",
    "build": "vue-tsc -b && npm run typecheck:tests && vite build",
    "build:preview": "npm run build && vite preview",
    "preview": "vite preview",
    "preemulators": "npm run build:functions",
    "emulators": "firebase emulators:start --project prepaid-ai-emulator",
    "emulators:wait": "node scripts/wait-for-emulators.mjs",
    "emulators:seed": "node scripts/emulator-seed.mjs",
    "emulators:clear": "node scripts/emulator-clear.mjs",
    "emulators:clear:firestore": "node scripts/emulator-clear.mjs firestore",
    "emulators:clear:auth": "node scripts/emulator-clear.mjs auth",
    "pretest:e2e": "npm run build:functions",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "pretest:e2e:standalone": "npm run build:functions",
    "test:e2e:standalone": "node scripts/test-e2e-standalone.mjs",
    "test:ct": "playwright test --config=playwright-ct.config.ts",
    "test": "npm run test:e2e && npm run test:ct && npm run test:pwa",
    "pretest:e2e:ui": "npm run build:functions",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "pretest:e2e:headed": "npm run build:functions",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:pwa": "playwright test --config=playwright-pwa.config.ts"
  },
  "dependencies": {
    "firebase": "^12.9.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.25",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/experimental-ct-vue": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "firebase-admin": "^13.6.1",
    "firebase-tools": "^15.6.0",
    "jimp": "^1.6.0",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.0.0",
    "vue-tsc": "^3.1.5",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0"
  }
}
